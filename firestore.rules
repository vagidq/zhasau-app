rules_version = '2';
// Схема приложения Zhasau (клиент Flutter):
//   users/{uid}                    — профиль (name, bio, photoUrl, xp, fcmToken, …)
//   users/{uid}/goals/{goalId}
//   users/{uid}/tasks/{taskId}
//   users/{uid}/notifications/{id} — внутриигровая лента (type, title, body, read, createdAt, …)
//   admins/{uid}                 — если документ существует и uid == auth.uid, этот пользователь админ (только чтение своей записи)
// Админ: добавьте в Firebase Console документ admins/<Firebase Auth UID> с любым полем, например { "role": "admin" }.
// Админ может читать любые users/**; писать — только в свои данные.
// Корневые коллекции tasks/goals/habits и т.д. клиентом не используются — закрыты явно.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{adminId} {
      allow read: if isOwner(adminId);
      allow write: if false;
    }

    match /tasks/{document=**} {
      allow read, write: if false;
    }
    match /goals/{document=**} {
      allow read, write: if false;
    }
    match /habits/{document=**} {
      allow read, write: if false;
    }
    match /user_balances/{document=**} {
      allow read, write: if false;
    }
    match /user_rewards/{document=**} {
      allow read, write: if false;
    }
    match /point_transactions/{document=**} {
      allow read, write: if false;
    }
    match /action_logs/{document=**} {
      allow read, write: if false;
    }
    match /periods/{document=**} {
      allow read, write: if false;
    }
    match /task_periods/{document=**} {
      allow read, write: if false;
    }
    match /rewards/{document=**} {
      allow read, write: if false;
    }

    match /users/{userId}/{document=**} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }
  }
}
