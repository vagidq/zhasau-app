rules_version = '2';
// Схема приложения Zhasau (клиент Flutter):
//   users/{docId}                  — профиль. docId может быть как auth.uid (legacy),
//                                    так и читаемым `user-<name>-<rnd>`. В новом
//                                    формате внутри документа есть поле `uid` = auth.uid.
//   users/{docId}/goals/{goalId}
//   users/{docId}/tasks/{taskId}
//   users/{docId}/habits/{habitId}
//   users/{docId}/notifications/{id}
//   users/{docId}/shopRewards/{rewardId}
//   users/{docId}/shopPurchases/{purchaseId}
//
// Принцип владения:
//   - Legacy:  docId == auth.uid                           → владелец.
//   - Modern:  users/{docId}.data.uid == auth.uid          → владелец.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    match /tasks/{document=**} {
      allow read, write: if false;
    }
    match /goals/{document=**} {
      allow read, write: if false;
    }
    match /habits/{document=**} {
      allow read, write: if false;
    }
    match /user_balances/{document=**} {
      allow read, write: if false;
    }
    match /user_rewards/{document=**} {
      allow read, write: if false;
    }
    match /point_transactions/{document=**} {
      allow read, write: if false;
    }
    match /action_logs/{document=**} {
      allow read, write: if false;
    }
    match /periods/{document=**} {
      allow read, write: if false;
    }
    match /task_periods/{document=**} {
      allow read, write: if false;
    }
    match /rewards/{document=**} {
      allow read, write: if false;
    }

    match /users/{docId} {
      function existingUidMatches() {
        return resource != null &&
          'uid' in resource.data &&
          resource.data.uid == request.auth.uid;
      }
      function incomingUidMatches() {
        return request.resource != null &&
          'uid' in request.resource.data &&
          request.resource.data.uid == request.auth.uid;
      }

      function isOwnerOfThisUserDoc() {
        return isSignedIn() && (
          request.auth.uid == docId ||
          existingUidMatches() ||
          incomingUidMatches()
        );
      }

      allow read: if isOwnerOfThisUserDoc();
      allow write: if isOwnerOfThisUserDoc();

      match /{document=**} {
        function parentDoc() {
          return get(/databases/$(database)/documents/users/$(docId));
        }
        function ownsParent() {
          return isSignedIn() && (
            request.auth.uid == docId ||
            ('uid' in parentDoc().data &&
              parentDoc().data.uid == request.auth.uid)
          );
        }

        allow read: if ownsParent();
        allow write: if ownsParent();
      }
    }
  }
}
