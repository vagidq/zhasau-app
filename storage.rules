rules_version = '2';
// Правила для Firebase Storage (отдельно от Firestore!).
// В консоли: Build → Storage → Rules — вставьте этот файл или выполните:
//   firebase deploy --only storage
//
// Путь в приложении: users/{uid}/profile_* , users/{uid}/shop_reward_*
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
